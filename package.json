{
  "name": "nct-api-sql-sub",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "predev": "node scripts/prepare-local-d1.mjs",
    "dev": "wrangler dev --local --port 8791 --persist-to .wrangler/state",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck",
    "db:migrate": "wrangler d1 migrations apply DB --local --persist-to .wrangler/state",
    "db:migrate:remote": "wrangler d1 migrations apply DB --remote"
  },
  "dependencies": {
    "hono": "^4.12.14",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260418.1",
    "typescript": "^6.0.3",
    "wrangler": "^4.83.0"
  }
}
