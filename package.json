{
  "name": "nct-api-sql-sub",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "predev": "node scripts/prepare-local-d1.mjs",
    "dev": "wrangler dev --local --port 8791 --persist-to .wrangler/state",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:jsx": "vitest run src/site/no-torsion-form-page.test.ts",
    "test:watch": "vitest",
    "check": "npm run typecheck && npm run test",
    "db:migrate": "wrangler d1 migrations apply DB --local --persist-to .wrangler/state",
    "db:migrate:remote": "wrangler d1 migrations apply DB --remote"
  },
  "dependencies": {
    "china-area-data": "^5.0.1",
    "hono": "^4.12.14",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260418.1",
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "wrangler": "^4.83.0"
  }
}
